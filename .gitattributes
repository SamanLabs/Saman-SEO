# Enforce LF line endings for all text files on checkout.
* text=auto eol=lf

# Ensure these files are always treated as text with LF endings.
*.php text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.less text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf

# Denote binary files that should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
